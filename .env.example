# Copy this file to `.env` for local development.
# `.env` is ignored by git on purpose.

# Runtime mode
APP_ENV=local
DEBUG=false
API_HOST=127.0.0.1
API_PORT=8000
API_RELOAD=true

# External API keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Local storage paths
DATA_DIR=./data
RAW_DATA_DIR=./data/raw
PROCESSED_DATA_DIR=./data/processed
ARTIFACT_DIR=./artifacts
LOG_DIR=./logs

# Safety / data movement defaults
ALLOW_EXTERNAL_UPLOAD=false
ALLOW_CLOUD_SYNC=false
SAVE_CAPTURED_MEDIA_LOCAL_ONLY=true
EXPORT_DEBUG_VIDEO=false
